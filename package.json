{
  "name": "lucky-draw",
  "version": "0.1.0",
  "description": "A pure frontend lucky draw web application",
  "type": "module",
  "scripts": {
    "serve": "bunx serve .",
    "build": "bun build script.ts --outfile script.js --target browser",
    "fix": "biome check --write .",
    "check:type": "tsc --noEmit",
    "check:biome": "biome check .",
    "check": "bun run check:type && bun run check:biome"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/bun": "^1.3.12",
    "typescript": "^6.0.2"
  },
  "keywords": [
    "lucky-draw",
    "raffle",
    "random-selection"
  ],
  "license": "Apache-2.0"
}
